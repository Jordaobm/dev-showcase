{
  "name": "dev-showcase",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev-https": "next dev --webpack --experimental-https",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:update-snapshots": "playwright test --update-snapshots",
    "test:coverage": "playwright test --project=chromium",
    "test:coverage:check": "node scripts/check-coverage-threshold.mjs",
    "verify:architecture": "node scripts/verify-architecture.mjs",
    "check": "npm run lint && tsc --noEmit && npm run verify:architecture && rm -rf .next && npm test && npm run test:coverage:check",
    "check:log": "npm run check > log.txt 2>&1",
    "check:feature": "node scripts/check-feature.mjs",
    "sonar:up": "docker compose -f docker-compose.sonar.yml up -d sonarqube sonar-db",
    "sonar:scan": "docker compose --env-file .env.local -f docker-compose.sonar.yml --profile scan run --rm sonar-scanner",
    "sonar:down": "docker compose -f docker-compose.sonar.yml down",
    "metrics:export": "node scripts/export-metrics.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@remotion/cli": "4.0.460",
    "@remotion/google-fonts": "^4.0.460",
    "@serwist/next": "^9.5.7",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.100.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/qrcode": "^1.5.6",
    "@types/three": "^0.184.1",
    "axios": "^1.15.2",
    "bcrypt": "^6.0.0",
    "crypto": "^1.0.1",
    "gsap": "^3.15.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "next-intl": "^4.9.1",
    "next-qrcode": "^2.5.1",
    "nodemailer": "^7.0.13",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.7.0",
    "remotion": "4.0.460",
    "resend": "^6.12.4",
    "serwist": "^9.5.7",
    "three": "~0.184.0",
    "tw-animate-css": "^1.4.0",
    "wa-sqlite": "^1.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@remotion/eslint-plugin": "^4.0.460",
    "@swc/core": "^1.15.43",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "monocart-coverage-reports": "^2.12.12",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
